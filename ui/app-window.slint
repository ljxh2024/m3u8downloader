import {
    TabWidget,
    LineEdit,
    Button,
    VerticalBox,
    HorizontalBox,
    CheckBox
} from "std-widgets.slint";

import { LoadingSpinner } from "loading-spinner.slint";

export component AppWindow inherits Window {
    title: "M3U8Downloader";
    
    // 按钮组
    in-out property <bool> enable-start-btn: true;
    in-out property <bool> enable-pause-btn: false;
    in-out property <bool> enable-cancel-btn: false;

    // 状态组
    in-out property <bool> is-downloading: false;
    in-out property <bool> is-pause: false;
    in-out property <bool> has-failed-file: false;
    in-out property <bool> is-convert: false;
    in-out property <bool> is-delete-slice: false;
    in-out property <bool> show-loading: false;

    // 输入组（后端可读可写）
    // in-out property <string> work-dir;
    in-out property <string> work-dir: "F:\\temp";
    in-out property <int> total_nums;
    in-out property <int> downloaded_nums;
    in-out property <string> content-length;

    // 输入组（后端只读）
    // out property <string> m3u8-url;
    out property <string> m3u8-url: "http://localhost/res/videos/m3u8/1/index.m3u8";
    // out property <string> video-name;
    out property <string> video-name: "m3u8test";
    out property <string> threads: 4;
    out property <string> retry: 3;
    out property <string> timeout: 5;
    out property <string> message;
    out property <bool> is-err-msg;

    out property <string> github: "https://github.com/ljxh2024/m3u8downloader";

    // 回调函数
    callback select-dir();
    callback open-failed-file();
    callback start-download();
    callback pause-download();
    callback cancel-download();

    callback show-message(string, bool);
    show-message(msg, err) => {
        root.message = msg;
        root.is-err-msg = err;
    }

    // 总布局
    TabWidget {
        // 首页
        Tab {
            title: "Home";
            VerticalBox {
                // 输入组件，3列
                GridLayout {
                    spacing: 6px;
                    // 工作目录
                    Row {
                        Rectangle {
                            width: 104px;
                            Text {
                                text: "Working Directory";
                            }
                            Text {
                                x: 102px;
                                text: "*";
                                color: red;
                            }
                        }
                        LineEdit {
                            text <=> root.work-dir;
                            read-only: true;
                            enabled: !root.is-downloading;
                        }
                        Button {
                            enabled: !root.is-downloading;
                            text: "Change";
                            clicked => { root.select-dir(); }
                        }
                    }
                    // 视频名称
                    Row {
                        Rectangle {
                            Text {
                                text: "Video Name";
                            }
                            Text {
                                x: 87px;
                                text: "*";
                                color: red;
                            }
                        }
                        LineEdit {
                            text <=> root.video-name;
                            colspan: 2;
                            enabled: !root.is-downloading;
                        }
                    }
                    // M3U8 URL
                    Row {
                        Rectangle {
                            Text {
                                text: "M3U8 URL";
                            }
                            Text {
                                x: 80px;
                                text: "*";
                                color: red;
                            }
                        }
                        LineEdit {
                            text <=> root.m3u8-url;
                            colspan: 2;
                            enabled: !root.is-downloading;
                        }
                    }
                    // 线程数
                    Row {
                        Rectangle {
                            Text {
                                text: "Threads";
                            }
                        }
                        LineEdit {
                            text <=> root.threads;
                            input-type: number;
                            colspan: 2;
                            enabled: !root.is-downloading || root.is-pause;
                        }
                    }
                    // 重试次数
                    Row {
                        Rectangle {
                            Text {
                                text: "Retry";
                            }
                        }
                        LineEdit {
                            text <=> root.retry;
                            input-type: number;
                            colspan: 2;
                            enabled: !root.is-downloading || root.is-pause;
                        }
                    }
                    // 超时
                    Row {
                        Rectangle {
                            Text {
                                text: "Timeout(s)";
                            }
                        }
                        LineEdit {
                            text <=> root.timeout;
                            input-type: number;
                            colspan: 2;
                            enabled: !root.is-downloading || root.is-pause;
                        }
                    }
                }
                // 转换MP4选项
                VerticalBox {
                    CheckBox {
                        text: "Convert to MP4 after downloaded";
                        checked <=> root.is-convert;
                        enabled: !root.is-downloading || root.is-pause;
                        toggled() => {
                            if !self.checked && root.is-delete-slice {
                                root.is-delete-slice = false;
                            }
                        }
                    }
                    CheckBox {
                        text: "Delete the segments after converted";
                        checked <=> root.is-delete-slice;
                        enabled: root.is-convert && (!root.is-downloading || root.is-pause);
                    }
                }
                // 按钮事件操作
                HorizontalBox {
                    Button {
                        text: root.is-pause ? "Continue" : "Download";
                        enabled: root.enable-start-btn && !root.work-dir.is-empty && !root.video-name.is-empty && !root.m3u8-url.is-empty;
                        primary: true;
                        clicked => { root.start-download(); }
                    }
                    Button {
                        text: "Pause";
                        enabled: root.enable-pause-btn;
                        clicked => { root.pause-download(); }
                    }
                    Button {
                        text: "Cancel";
                        enabled: root.enable-cancel-btn;
                        clicked => { root.cancel-download(); }
                    }
                }
                HorizontalBox {
                    padding-bottom: 0px;
                    Text {
                        text: "Progress " + (root.total_nums > 0 ? root.downloaded_nums + " / " + root.total_nums : "");
                    }
                    Text {
                        text: root.total_nums > 0 ? root.content-length : "";
                    }
                }
                HorizontalBox {
                    padding-top: 0px;
                    padding-bottom: 0px;
                    Text {
                        text: root.message;
                        wrap: word-wrap;
                        color: root.is-err-msg ? red : black;
                        horizontal-alignment: center;
                    }
                    if root.show-loading : LoadingSpinner{
                        ring: !root.is-pause;
                    }
                }
                if root.has-failed-file : HorizontalBox {
                    padding-top: 0px;
                    padding-bottom: 0px;
                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.open-failed-file(); }
                        Text {
                            text: "Failed file";
                            color: #3399ff;
                        }
                    }
                }
            }
        }
        // 关于页
        Tab {
            title: "About";
            Rectangle {
                Text {
                    y: 140px;
                    text: "M3U8Downloader";
                }
                Text {
                    y: 160px;
                    text: "Version 0.1.0";
                }
                Text {
                    y: 180px;
                    text: "Github:";
                }
                Text {
                    y: 200px;
                    text: root.github;
                    color: #007fff;
                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            Platform.open-url(root.github);
                        }
                    }
                }
            }
        }
    }
}